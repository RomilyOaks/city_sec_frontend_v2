# Sample environment variables for MCP server
# Copy this file to ".env" and edit the values for your local MySQL setup.

# Full connection URI (takes precedence if defined)
# DATABASE_URL=mysql://user:password@localhost:3306/database_name

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=        # define aquí tu contraseña local, p. ej. "Effata"
DB_NAME=citizen_security_v2

# optional pool settings
DB_POOL_MAX=10
DB_POOL_MIN=0

# server port
PORT=3001
